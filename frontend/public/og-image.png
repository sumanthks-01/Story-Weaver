<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea"/>
      <stop offset="100%" style="stop-color:#764ba2"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="60" y="60" width="1080" height="510" rx="32" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
  <text x="600" y="240" font-family="system-ui, sans-serif" font-size="96" font-weight="800" fill="white" text-anchor="middle">📖 Story Weaver</text>
  <text x="600" y="330" font-family="system-ui, sans-serif" font-size="36" fill="rgba(255,255,255,0.85)" text-anchor="middle">Collaborative storytelling, one sentence at a time</text>
  <text x="600" y="430" font-family="system-ui, sans-serif" font-size="28" fill="rgba(255,255,255,0.65)" text-anchor="middle">Each writer sees only the last sentence — creating unexpected twists!</text>
  <text x="600" y="520" font-family="system-ui, sans-serif" font-size="24" fill="rgba(255,255,255,0.5)" text-anchor="middle">story-weaver-xi.vercel.app</text>
</svg>
